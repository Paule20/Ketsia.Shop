KERNEL_CLASS='App\Kernel'
APP_ENV=test
APP_SECRET='test_secret_key_for_testing_only'

# La base de donnees de test est la meme que dev mais avec le suffixe _test
# Doctrine ajoute automatiquement "_test" au nom de la BDD (voir doctrine.yaml when@test)
DATABASE_URL="mysql://ketsia_user:ketsia_password@127.0.0.1:3306/ketsia_shop?serverVersion=8.0&charset=utf8mb4"

JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change_me_to_a_secure_passphrase
