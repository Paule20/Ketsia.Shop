# =============================================================
# Ketsia.shop — Variables d'environnement
# =============================================================
# Copiez ce fichier en ".env.local" et remplissez les valeurs.
# NE JAMAIS committer .env.local (il est dans .gitignore).
# Ce fichier .env.example PEUT etre committe : il ne contient
# aucune valeur sensible, uniquement des explications.
# =============================================================

# --- Symfony ---
# Environnement : dev | test | prod
APP_ENV=dev

# Cle secrete Symfony (generer avec : php -r "echo bin2hex(random_bytes(16));")
APP_SECRET=votre_cle_secrete_32_caracteres

# --- Base de donnees MySQL ---
# Format : mysql://USER:PASSWORD@HOST:PORT/NOM_BDD?serverVersion=8.0&charset=utf8mb4
# En local sans Docker :
DATABASE_URL="mysql://root:@127.0.0.1:3306/ketsia_shop?serverVersion=8.0&charset=utf8mb4"
# Avec Docker (le host est le nom du service docker-compose) :
# DATABASE_URL="mysql://ketsia_user:ketsia_password@database:3306/ketsia_shop?serverVersion=8.0&charset=utf8mb4"

# --- JWT (LexikJWTAuthenticationBundle) ---
# Chemins vers les cles RSA (generees avec la commande ci-dessous)
# Generation : php bin/console lexik:jwt:generate-keypair
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
# Passphrase utilisee lors de la generation des cles (choisir une valeur forte)
JWT_PASSPHRASE=votre_passphrase_jwt_secrete

# --- Base de donnees MongoDB (messages de contact) ---
# Format : mongodb://USER:PASSWORD@HOST:PORT/?authSource=admin
# En local sans Docker :
MONGODB_URI="mongodb://ketsia_mongo:ketsia_mongo_password@127.0.0.1:27018/?authSource=admin"
MONGODB_DB=ketsia_shop
# Avec Docker (le host est le nom du service docker-compose) :
# MONGODB_URI="mongodb://ketsia_mongo:ketsia_mongo_password@mongo:27017/?authSource=admin"
# En production (MongoDB Atlas) :
# MONGODB_URI="mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority"

# --- CORS (NelmioCorsBundle) ---
# Origines autorisees pour les requetes cross-origin du frontend
# En dev : accepte localhost sur n'importe quel port
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
# En production : remplacer par l'URL exacte du frontend
# CORS_ALLOW_ORIGIN='^https://www\.ketsia\.shop$'
